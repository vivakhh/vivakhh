{
  "hosting": [
    {
      "site": "yakmate-app",
      "public": "01_YakMate_App",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "*.zip",
        "*.sh"
      ],
      "rewrites": [
        {
          "source": "/",
          "destination": "/landing.html"
        }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
